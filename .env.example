# ═══════════════════════════════════════════════════════════════
# Hermes V2 — Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#   nano .env

# ═══════════════════════════════════════════════════════════════
# 🔑 API KEYS (REQUIRED)
# ═══════════════════════════════════════════════════════════════

# OpenRouter API Key (Primary LLM provider)
# Get yours at: https://openrouter.ai/settings/credits
# Cost: ~$0.003 per answer
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Google Gemini API Key (Optional backup)
# Get yours at: https://aistudio.google.com/appkey
GEMINI_API_KEY=

# Langfuse (Optional — LLM observability & tracing)
# Get yours at: https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ═══════════════════════════════════════════════════════════════
# 🗄️ DATABASE CONFIGURATION
# ═══════════════════════════════════════════════════════════════

# PostgreSQL
DB_USER=upsc_user
DB_PASSWORD=upsc_password
DB_NAME=upsc_db

# Neo4j
NEO4J_USER=neo4j
NEO4J_PASSWORD=upsc_neo4j_password

# MinIO (Object Storage)
MINIO_USER=hermes_admin
MINIO_PASSWORD=hermes_secret_2026

# ═══════════════════════════════════════════════════════════════
# 🚀 APPLICATION SETTINGS
# ═══════════════════════════════════════════════════════════════

# Environment: production | development | testing
APP_ENV=production

# Debug mode (set to true for development)
APP_DEBUG=false

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Server port
PORT=8000

# ═══════════════════════════════════════════════════════════════
# 🔧 ADVANCED SETTINGS
# ═══════════════════════════════════════════════════════════════

# LLM Cache TTL in seconds (default: 3600 = 1 hour)
LLM_CACHE_TTL=3600

# Max tokens for LLM response
LLM_MAX_TOKENS=2048

# LLM request timeout in seconds
LLM_TIMEOUT=120

# Rate limit (requests per minute)
RATE_LIMIT_PER_MINUTE=60

# CORS origins (comma-separated)
CORS_ORIGINS=https://hermes.upsc.ai,http://localhost:3000

# ═══════════════════════════════════════════════════════════════
# 🎮 GPU CONFIGURATION
# ═══════════════════════════════════════════════════════════════

# GPU device ID (0 for first GPU)
CUDA_VISIBLE_DEVICES=0

# Enable/disable GPU
ENABLE_GPU=true
