# Git LFS tracking for large data files
*.jsonl filter=lfs diff=lfs merge=lfs -text
databases/** filter=lfs diff=lfs merge=lfs -text

# Text files should use LF line endings
*.py text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.env* text eol=lf
*.ps1 text eol=crlf
